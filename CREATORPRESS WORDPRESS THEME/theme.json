{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 2,
  "settings": {
    "color": {
      "custom": true,
      "customGradient": false,
      "palette": [
        { "slug": "slate-950", "color": "#0f172a", "name": "Dark" },
        { "slug": "slate-900", "color": "#111827", "name": "Surface" },
        { "slug": "slate-100", "color": "#f8fafc", "name": "Light" },
        { "slug": "accent", "color": "#7c3aed", "name": "Accent" }
      ]
    },
    "typography": {
      "fontFamilies": [
        {
          "fontFamily": "Inter, system-ui, sans-serif",
          "slug": "inter",
          "name": "Inter"
        }
      ],
      "customFontSize": true
    },
    "spacing": {
      "customPadding": true,
      "customMargin": true
    },
    "layout": {
      "contentSize": "720px",
      "wideSize": "1120px"
    }
  }
}
