{
  "name": "creatorpress-theme",
  "version": "1.0.0",
  "private": true,
  "description": "CreatorPress WordPress theme with Tailwind CSS and lightweight vanilla JS.",
  "scripts": {
    "dev": "tailwindcss -i ./assets/css/tailwind.css -o ./assets/css/style.css --watch",
    "build": "tailwindcss -i ./assets/css/tailwind.css -o ./assets/css/style.css --minify"
  },
  "devDependencies": {
